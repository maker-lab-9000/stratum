# Stratum configuration (spec §9.1). Copy to `.env` and fill in.
# Secrets live here / in the environment only — never in the DB or API responses.

# --- LLM providers (at least one enables the verdict; none → degraded reports) --
# GET /api/models lists models for whichever keys are set. Keys are never
# returned to the browser or stored in the DB.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Offline ASN/geo enrichment (MaxMind GeoLite2) ---------------------------
# Free licence key from https://www.maxmind.com/. When set and the databases are
# absent, they download once on boot into MAXMIND_DB_DIR. Unset → ASN/geo show
# "unknown" and the rest of the pipeline still works.
MAXMIND_LICENSE_KEY=
# MAXMIND_DB_DIR=/app/backend/data/geoip

# --- Report presentation -----------------------------------------------------
# Shown on every report's map; disclose where the runner physically sits (§10).
VANTAGE_LABEL=unknown vantage

# --- Sampling defaults (the launch form can override per run) -----------------
DEFAULT_REQUEST_COUNT=4
DEFAULT_INTERVAL_MS=0

# --- Storage -----------------------------------------------------------------
# Default (in-image) is SQLite on the mounted volume. For the optional Postgres
# service (docker compose --profile postgres up) use, e.g.:
#   DATABASE_URL=postgresql+psycopg://stratum:stratum@db:5432/stratum
# DATABASE_URL=sqlite:////app/backend/data/stratum.db

# --- Pipeline ----------------------------------------------------------------
# PIPELINE_CONCURRENCY=2
# LOG_LEVEL=INFO

# --- Optional access gate (off by default for trusted LAN use) ---------------
# Do NOT expose Stratum publicly without this (§10). Wired in T22.
# AUTH_ENABLED=false
# BASIC_AUTH_USER=
# BASIC_AUTH_PASS=
